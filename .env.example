# Agent Zero Corporate Edition — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Authentication ───────────────────────────────────────────────
# Web UI login credentials
AUTH_LOGIN=admin
AUTH_PASSWORD=changeme

# ── LLM Backend — AWS Bedrock ────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── TLS / Corporate Proxy ────────────────────────────────────────
# Set to false to disable TLS verification (not recommended for production)
# TLS_VERIFY=true
# Path inside container to a custom CA bundle (upload via Settings > Network > TLS)
# TLS_CA_BUNDLE=

# ── Optional ─────────────────────────────────────────────────────
# Route browser agent traffic through corporate proxy
# BROWSER_PROXY=http://proxy.corp.example.com:8080

# SearXNG search (auto-configured inside container)
# SEARXNG_URL=http://localhost:8080
