# Agent Zero Corporate Edition — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Instance Identity ─────────────────────────────────────────────
# COMPOSE_PROJECT_NAME namespaces ALL Docker resources (containers, volumes, networks).
# Change this to run multiple isolated instances side by side.
# Example: production=agentzero, test=agentzero-test
COMPOSE_PROJECT_NAME=agentzero

# Container name (default: agent-zero)
CONTAINER_NAME=agent-zero

# Port to bind on the host (default: 50080)
PORT=50080

# ── Authentication (REQUIRED) ─────────────────────────────────────
# Web UI login credentials
AUTH_LOGIN=admin
AUTH_PASSWORD=changeme

# ── Image ─────────────────────────────────────────────────────────
# Docker image to run. Defaults to locally built image.
# Override to pull from Docker Hub:
# AGENT_ZERO_IMAGE=your-dockerhub-user/agent-zero-hardened:latest
AGENT_ZERO_IMAGE=agent-zero-hardened:latest

# ── LLM Backend (OPTIONAL at startup) ────────────────────────────
# Configure your LLM provider via Settings in the UI after first login.
# You can set API keys here OR enter them in Settings > Model.
#
# AWS Bedrock (recommended for corporate):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
#
# Anthropic direct:
# ANTHROPIC_API_KEY=
#
# OpenAI:
# OPENAI_API_KEY=
#
# OpenRouter:
# OPENROUTER_API_KEY=

# ── TLS / Corporate Proxy (OPTIONAL) ─────────────────────────────
# Configure TLS via Settings > Network > TLS in the UI after first login.
# Or set here to apply from startup:
#
# BROWSER_PROXY=http://proxy.corp.example.com:8080
